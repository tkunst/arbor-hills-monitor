graph LR
  %% program -> data store lineage; dotted = read, bold = write
  ds_conservancy_sheet[("Conservancy Case-File Sheet")]
  ds_drive_archive[("Google Drive PDF Archive")]
  ds_nsite[("EGLE nSITE Portal (Air)")]
  ds_wds[("EGLE WDS Portal (Solid Waste)")]
  ds_mmpc[("Washtenaw County MMPC Site")]
  ds_pfas[("EGLE PFAS Investigation Pages (michigan.gov)")]
  ds_gfl_air[("GFL Perimeter Air ArcGIS FeatureServer (Barr, public)")]
  ds_smtp[("Email Recipients (SMTP)")]
  ds_anthropic[("Anthropic Claude API")]
  ds_config[("config.yml (risk register + settings)")]
  sheet_writer["sheet_writer"]
  sheet_writer -. read .-> ds_conservancy_sheet
  sheet_writer ==>|write| ds_conservancy_sheet
  archive_client["archive_client"]
  archive_client ==>|write| ds_drive_archive
  nsite_client["nsite_client"]
  nsite_client -. read .-> ds_nsite
  wds_client["wds_client"]
  wds_client -. read .-> ds_wds
  mmpc_client["mmpc_client"]
  mmpc_client -. read .-> ds_mmpc
  pfas_client["pfas_client"]
  pfas_client -. read .-> ds_pfas
  gfl_air_client["gfl_air_client"]
  gfl_air_client -. read .-> ds_gfl_air
  email_alerts["email_alerts"]
  email_alerts ==>|write| ds_smtp
  egle_doc_parser["egle_doc_parser"]
  egle_doc_parser -. read .-> ds_anthropic
  config_loader["config_loader"]
  config_loader -. read .-> ds_config
  wds_archiver["wds_archiver"]
  wds_archiver -. read .-> ds_wds
  wds_archiver ==>|write| ds_drive_archive
  mmpc_archiver["mmpc_archiver"]
  mmpc_archiver ==>|write| ds_drive_archive
