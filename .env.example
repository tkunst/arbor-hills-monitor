# Copy to .env and fill in. .env is gitignored — never commit real values.
# See scripts/setup_gcp.md for how to obtain each value.

# --- Anthropic (document classification) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Sheets (service account) ---
# Path to the downloaded service-account key JSON (local dev). In GitHub Actions
# this is provided as the GDRIVE_SA_KEY secret (the JSON contents, written to a
# temp file by the workflow). Share the .gsheet with the service-account email
# as Editor; no other credential needed in the repo.
GDRIVE_SA_KEY=./gdrive-sa-key.json
# The Google Sheet ID (the .gsheet case file). From the sheet's URL.
GSHEET_ID=your-sheet-id-here
# GDRIVE_FOLDER_ID is no longer used (ADR 006: state + links live in the Sheet,
# not a Drive folder). Safe to omit.

# --- Email alerts (SMTP, not Gmail MCP — MCP is interactive-only) ---
# Gmail: enable 2FA -> generate an App Password -> use smtp.gmail.com:587 (TLS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-address@example.com
SMTP_PASSWORD=your-app-password-here

# --- Optional: durable PDF mirror (OAuth-as-user, ADR 007) ---
# Only needed for the archiver. scripts/oauth_setup.py mints all four. Leave
# unset to disable archiving (archiver.py becomes a no-op). drive.file scope.
GOAUTH_CLIENT_ID=your-oauth-client-id
GOAUTH_CLIENT_SECRET=your-oauth-client-secret
GOAUTH_REFRESH_TOKEN=your-oauth-refresh-token
GOAUTH_ARCHIVE_FOLDER_ID=the-mirror-folder-id
